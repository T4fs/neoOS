#!/bin/bash
# neoOS Wallpaper Manager
# Manage wallpapers and apply them to Hyprland

set -e

# Configuration
WALLPAPER_DIR="$HOME/Pictures/Wallpapers"
CONFIG_DIR="$HOME/.config"
HYPR_CONFIG="$CONFIG_DIR/hypr/hyprpaper.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Create wallpaper directory if it doesn't exist
mkdir -p "$WALLPAPER_DIR"

# Function to display usage
show_usage() {
    echo "Usage: neoos-wallpaper [option]"
    echo ""
    echo "Options:"
    echo "  -l, --list          List available wallpapers"
    echo "  -s, --select        Select and apply a wallpaper"
    echo "  -a, --apply FILE    Apply a specific wallpaper"
    echo "  -r, --random        Apply a random wallpaper"
    echo "  -d, --download      Download wallpapers from online sources"
    echo "  -h, --help          Show this help message"
    echo ""
}

# Function to list wallpapers
list_wallpapers() {
    echo -e "${CYAN}Available wallpapers:${NC}"
    echo ""
    
    if [ -d "$WALLPAPER_DIR" ]; then
        count=1
        for wallpaper in "$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp}; do
            if [ -f "$wallpaper" ]; then
                echo -e "  ${YELLOW}$count)${NC} $(basename "$wallpaper")"
                ((count++))
            fi
        done
        
        if [ $count -eq 1 ]; then
            echo -e "  ${YELLOW}No wallpapers found in $WALLPAPER_DIR${NC}"
        fi
    else
        echo -e "  ${YELLOW}Wallpaper directory not found${NC}"
    fi
}

# Function to select wallpaper
select_wallpaper() {
    echo -e "${CYAN}Select a wallpaper:${NC}"
    echo ""
    
    local wallpapers=()
    for wallpaper in "$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp}; do
        if [ -f "$wallpaper" ]; then
            wallpapers+=("$wallpaper")
        fi
    done
    
    if [ ${#wallpapers[@]} -eq 0 ]; then
        echo -e "${RED}No wallpapers found${NC}"
        return 1
    fi
    
    for i in "${!wallpapers[@]}"; do
        echo -e "  ${YELLOW}$((i+1)))${NC} $(basename "${wallpapers[$i]}")"
    done
    
    echo ""
    read -p "Enter wallpaper number: " choice
    
    if [[ $choice -ge 1 && $choice -le ${#wallpapers[@]} ]]; then
        apply_wallpaper "${wallpapers[$((choice-1))]}"
    else
        echo -e "${RED}Invalid selection${NC}"
        return 1
    fi
}

# Function to apply wallpaper
apply_wallpaper() {
    local wallpaper="$1"
    
    if [ ! -f "$wallpaper" ]; then
        echo -e "${RED}Wallpaper not found: $wallpaper${NC}"
        return 1
    fi
    
    echo -e "${GREEN}Applying wallpaper: $(basename "$wallpaper")${NC}"
    
    # Create hyprpaper config
    cat > "$HYPR_CONFIG" << EOF
preload = $wallpaper
wallpaper = ,$wallpaper
splash = false
ipc = off
EOF
    
    # Reload hyprpaper
    if command -v hyprctl &> /dev/null; then
        hyprctl hyprpaper preload "$wallpaper"
        hyprctl hyprpaper wallpaper ",$wallpaper"
    fi
    
    echo -e "${GREEN}Wallpaper applied successfully${NC}"
}

# Function to apply random wallpaper
apply_random_wallpaper() {
    local wallpapers=()
    for wallpaper in "$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp}; do
        if [ -f "$wallpaper" ]; then
            wallpapers+=("$wallpaper")
        fi
    done
    
    if [ ${#wallpapers[@]} -eq 0 ]; then
        echo -e "${RED}No wallpapers found${NC}"
        return 1
    fi
    
    local random_index=$(( RANDOM % ${#wallpapers[@]} ))
    apply_wallpaper "${wallpapers[$random_index]}"
}

# Function to download wallpapers
download_wallpapers() {
    echo -e "${CYAN}Downloading wallpapers...${NC}"
    
    # Create temp directory
    local temp_dir=$(mktemp -d)
    
    # Download some popular wallpapers
    echo -e "${YELLOW}Downloading Catppuccin wallpapers...${NC}"
    wget -q -P "$temp_dir" "https://github.com/catppuccin/catppuccin/raw/main/ram-wallpapers/ram-wallpaper-mocha.png" 2>/dev/null || true
    
    echo -e "${YELLOW}Downloading Tokyo Night wallpapers...${NC}"
    wget -q -P "$temp_dir" "https://raw.githubusercontent.com/enkia/tokyo-night-vscode-theme/master/background/tokyonight.png" 2>/dev/null || true
    
    echo -e "${YELLOW}Downloading Gruvbox wallpapers...${NC}"
    wget -q -P "$temp_dir" "https://raw.githubusercontent.com/morhetz/gruvbox/master/wallpapers/gruvbox-dark.png" 2>/dev/null || true
    
    # Move downloaded wallpapers
    for wallpaper in "$temp_dir"/*.{png,jpg,jpeg}; do
        if [ -f "$wallpaper" ]; then
            mv "$wallpaper" "$WALLPAPER_DIR/"
        fi
    done
    
    # Cleanup
    rm -rf "$temp_dir"
    
    echo -e "${GREEN}Wallpapers downloaded to $WALLPAPER_DIR${NC}"
}

# Main
while true; do
    case "$1" in
        -l|--list)
            list_wallpapers
            break
            ;;
        -s|--select)
            select_wallpaper
            break
            ;;
        -a|--apply)
            if [ -n "$2" ]; then
                apply_wallpaper "$2"
            else
                echo -e "${RED}Please specify a wallpaper file${NC}"
                show_usage
            fi
            break
            ;;
        -r|--random)
            apply_random_wallpaper
            break
            ;;
        -d|--download)
            download_wallpapers
            break
            ;;
        -h|--help)
            show_usage
            break
            ;;
        *)
            show_usage
            break
            ;;
    esac
done
